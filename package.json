{
  "name": "seedisplay",
  "version": "1.5.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --win -p always"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "AslakFAVREAU",
        "repo": "seedisplay"
      }
    ],
    "appId": "com.github.AslakFAVREAU.seedisplay",
    "afterSign": "./build/notarize.js",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false
    }
  },
  "author": "Evenement SOE",
  "license": "ISC",
  "devDependencies": {
    "electron": "^14.0.1",
    "electron-builder": "^23.3.3"
  },
  "dependencies": {
    "axios": "^0.20.0",
    "bootstrap": "^4.5.2",
    "config": "^3.3.1",
    "csv-parse": "^4.12.0",
    "csv-parser": "^2.3.3",
    "electron-builder-squirrel-windows": "^23.4.0",
    "electron-log": "^4.4.8",
    "electron-notarize": "^1.2.1",
    "electron-packager": "^15.1.0",
    "electron-updater": "^4.3.9",
    "jquery": "^3.5.1",
    "node-fetch": "^2.6.1",
    "popper.js": "^1.16.1",
    "request": "^2.88.2",
    "ssl-root-cas": "^1.3.1"
  }
}
