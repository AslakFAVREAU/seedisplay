{
  "name": "seedisplay",
  "version": "2.10.0",
  "description": "SEE Display Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "cross-env DEBUG_MODE=true electron .",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "start:offline": "electron . --offline",
    "test": "mocha test/**/*.test.js --exit",
    "test:performance": "mocha test/performance.test.js --timeout 120000",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "icons": "node scripts/generate-icons.js",
    "build": "electron-builder --linux AppImage --x64",
    "dist": "npm run version:patch && npm run build && git add package.json && git commit -m \"chore: bump version to v$(node -p \\\"require('./package.json').version\\\")\"",
    "publish": "electron-builder --linux AppImage --x64 --publish=always"
  },
  "keywords": [
    "electron",
    "display",
    "slideshow"
  ],
  "author": "SEE",
  "license": "MIT",
  "devDependencies": {
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "mocha": "^10.0.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.0"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bootstrap": "^4.6.2",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.6.2",
    "jquery": "^3.6.4",
    "popper.js": "^1.16.1"
  },
  "build": {
    "appId": "fr.see.seedisplay",
    "productName": "SEE Display",
    "directories": {
      "output": "dist/v${version}"
    },
    "files": [
      "**/*",
      "!test",
      "!docs",
      "!dist/**/*",
      "!scripts",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://soek.fr/updates/seedisplay"
      }
    ],
    "compression": "normal",
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "maintainer": "SEE <contact@soek.fr>",
      "vendor": "SEE",
      "synopsis": "Digital Signage Display Application",
      "description": "SEE Display - Application d'affichage dynamique pour écrans connectés."
    },
    "appImage": {
      "artifactName": "SEE-Display-${arch}.AppImage"
    }
  }
}
