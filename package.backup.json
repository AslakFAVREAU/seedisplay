{
  "name": "seedisplay",
  "version": "1.8.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "mocha --exit",
    "dist": "electron-builder",
    "publish": "electron-builder --win -p always"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "AslakFAVREAU",
        "repo": "seedisplay"
      }
    ],
    "appId": "com.github.AslakFAVREAU.seedisplay",
    "productName": "SEE Display",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!test/**/*",
      "!docs/**/*",
      "!build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
        "icon": "assets/icon.ico",
        "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SEE Display",
      "displayLanguageSelector": false,
      "installerLanguages": ["fr_FR", "en_US"]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    }
  },
  "author": "Evenement SOE",
  "license": "ISC",
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "mocha": "^10.2.0"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bootstrap": "^4.6.2",
    "config": "^3.3.12",
    "csv-parse": "^4.16.3",
    "csv-parser": "^2.3.5",
    "electron-builder-squirrel-windows": "^26.0.12",
    "electron-log": "^4.4.8",
    "electron-notarize": "^1.2.2",
    "electron-packager": "^17.1.2",
    "electron-updater": "^6.6.2",
    "jquery": "^3.7.1",
    "node-fetch": "^2.6.1",
    "popper.js": "^1.16.1",
    "ssl-root-cas": "^1.3.1"
  }
}
